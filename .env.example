# MongoDB — base URI without relying on path DB name; app uses MONGODB_DB_NAME
MONGODB_URI=mongodb://127.0.0.1:27017

# Dedicated database name (collections: promptgenerations)
MONGODB_DB_NAME=ai_prompt_generator

# Server
PORT=8000
# Comma-separated list of allowed web origins for CORS
CORS_ORIGINS=http://localhost:3000,https://aipromptgenerator.oxmite.com,https://prompt-creator-admin.oxmite.com

# Auth (same routes as ai_image_generator_backend — JWT + optional Google)
JWT_SECRET=change-me-to-a-long-random-string
# Google Sign-In: Web client ID from Google Cloud (used to verify idToken)
GOOGLE_CLIENT_ID=

# Gmail for OTP / password reset (optional in dev — OTP is logged if unset)
EMAIL_USER=
EMAIL_PASS=

# OpenAI (chat completion for prompt text)
OPENAI_API_KEY=
# Optional override (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Admin dashboard authentication
ADMIN_EMAIL=admin@gmail.com
ADMIN_PASSWORD=admin@gmail.com
ADMIN_JWT_SECRET=change-me-admin-secret

# Universal admin inter-service key — set this to a long random string.
# The universal admin backend sends this in X-Service-Key header when proxying
# requests to this backend (for user data, ban/unban, etc.).
# Must match the serviceKey stored in the universal admin's AppRegistry for this app.
INTERNAL_SERVICE_KEY=wifianalyzer-internal-service-key

# Push notifications (Firebase Admin service account JSON as one-line string)
# Important: in private_key use escaped newlines (\\n), not raw line breaks.
# Example:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...,"private_key":"-----BEGIN PRIVATE KEY-----\\nABC...\\n-----END PRIVATE KEY-----\\n",...}
FIREBASE_SERVICE_ACCOUNT=
# Same as admin-service style: JSON string or base64-encoded JSON
FIREBASE_SERVICE_ACCOUNT_JSON=
# Optional path to service account file (default: ./firebase-service-account.json)
FIREBASE_SERVICE_ACCOUNT_PATH=
