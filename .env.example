# Copy to `.env` in this folder (same directory as package.json). Keep this file; do not delete.
# Real secrets go only in `.env` (gitignored).

# MongoDB
MONGODB_URI=mongodb://localhost:27017/oceanic_ai

# Server
PORT=8000

# JWT (required)
JWT_SECRET=your-secret-key

# OpenAI (image generation)
OPENAI_API_KEY=

# Gmail OTP (app password recommended). If unset, the OTP is only printed in the server console.
EMAIL_USER=
EMAIL_PASS=
